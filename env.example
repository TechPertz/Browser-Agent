# Copy to .env and fill in as needed. .env is gitignored.
# (File named env.example — no leading dot — so editor/CI hooks don't treat it as a real .env.)

# Anthropic / LiteLLM
ANTHROPIC_API_KEY=

# Integrations (optional — provided at trial time)
GITHUB_TOKEN=
LINEAR_TOKEN=
JIRA_EMAIL=
JIRA_API_TOKEN=

# Langfuse self-hosted (optional)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000

# Browserbase (optional swap)
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=
